# Şablon — kopyalayıp .env yapın. .env git'e girmez.
#   copy .env.example .env

# docker-compose.yml içindeki Postgres ile birebir uyumlu
DATABASE_URL=postgresql*****
DB_ECHO=false
DEBUG=true

# Üretimde mutlaka değiştirin:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=degistir-bu-anahtari-uretimde-mutlaka
CARD_TOKEN_SECRET=degistir-bu-kart-anahtarini-da

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Web aynı origin'den servis edilir; bu liste yalnızca mobil/harici istemciler için
CORS_ORIGINS=["*"]

# Otobüs simülasyonu hız çarpanı (10 → gerçek 30 sn ≈ 5 sim-dakika)
SIM_SPEED=10
# Bir otobüsün "dolu" sayıldığı yolcu sayısı — yoğunluk renk kodu bundan hesaplanır
BUS_CAPACITY=40
