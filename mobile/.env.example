# Yerel ayarlar — bu dosyayı .env olarak kopyalayın. .env git'e girmez.
# Değişiklikten sonra: npx expo start -c

# Telefonla test ederken bilgisayarınızın AĞ adresini yazın, örn. http://192.168.1.20:8000
# Telefondaki "localhost" telefonun kendisidir — backend'e ulaşmaz.
EXPO_PUBLIC_BACKEND_URL=http://localhost:8000
