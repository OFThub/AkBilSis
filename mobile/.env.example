# Bu dosyayı ".env" adıyla kopyalayıp kendi değerlerinizi yazın.
# ".env" git'e girmez; gerçek adres yalnızca sizin makinenizde kalır.
# Değişiklikten sonra Metro önbelleğini temizleyin: npx expo start -c

# İzleme merkezi (backend) adresi.
# Telefonla test ederken bilgisayarınızın ağ adresini yazın — backend açılırken
# "Ağ (mobil)" satırında görünür. Bilgisayarda web modunda localhost yeterli.
EXPO_PUBLIC_BACKEND_URL=http://192.168.1.20:4000

# Otobüs simülasyonu hız çarpanı (10 → gerçek 30 sn ≈ 5 dk yolculuk).
# Gerçek zamanlı ilerleme için 1 yazın.
EXPO_PUBLIC_SIM_SPEED=10
